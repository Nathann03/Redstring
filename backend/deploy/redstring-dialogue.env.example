PATH=/opt/redstring/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
PYTHONPATH=/opt/redstring/backend/src
PORT=8000
REDSTRING_SECRET_KEY=replace-this-with-a-long-random-secret
REDSTRING_CHARACTER_FILE=/opt/redstring/backend/character_info.txt
REDSTRING_DIALOGUE_FILE=/opt/redstring/backend/data/npc_dialogue.json
REDSTRING_WARM_START=false

# Use one model source option.
REDSTRING_LLM_CONFIG=/opt/redstring/backend/config/local_llm_config.json
